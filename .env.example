# ============================================================
#  MODÈLE DE VARIABLES D'ENVIRONNEMENT
#  Copie ce fichier en `.env` puis remplis les valeurs.
#  cp .env.example .env   (ou copie/colle sous Windows)
# ============================================================

# 🗄️  PostgreSQL (Neon) — connexion DIRECTE (sans "-pooler") pour les migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# 🔜 Variables des briques suivantes (laissées ici pour mémoire) :
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# RESEND_API_KEY=""
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
